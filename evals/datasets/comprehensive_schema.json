{
  "$defs": {
    "Case": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "inputs": {
          "$ref": "#/$defs/EvalInput"
        },
        "metadata": {
          "anyOf": [
            {
              "$ref": "#/$defs/EvalMetadata"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "expected_output": {
          "anyOf": [
            {
              "$ref": "#/$defs/ReportExtraction"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "evaluators": {
          "default": [],
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/short_evaluator_Equals"
              },
              {
                "$ref": "#/$defs/evaluator_Equals"
              },
              {
                "const": "EqualsExpected",
                "type": "string"
              },
              {
                "$ref": "#/$defs/short_evaluator_EqualsExpected"
              },
              {
                "$ref": "#/$defs/short_evaluator_Contains"
              },
              {
                "$ref": "#/$defs/evaluator_Contains"
              },
              {
                "$ref": "#/$defs/short_evaluator_IsInstance"
              },
              {
                "$ref": "#/$defs/evaluator_IsInstance"
              },
              {
                "$ref": "#/$defs/short_evaluator_MaxDuration"
              },
              {
                "$ref": "#/$defs/short_evaluator_LLMJudge"
              },
              {
                "$ref": "#/$defs/evaluator_LLMJudge"
              },
              {
                "$ref": "#/$defs/short_evaluator_HasMatchingSpan"
              },
              {
                "$ref": "#/$defs/evaluator_HasMatchingSpan"
              }
            ]
          },
          "title": "Evaluators",
          "type": "array"
        }
      },
      "required": [
        "inputs"
      ],
      "title": "Case",
      "type": "object"
    },
    "EvalInput": {
      "additionalProperties": false,
      "description": "Input for a single eval case: the report text and optional exam description.",
      "properties": {
        "report_text": {
          "title": "Report Text",
          "type": "string"
        },
        "study_description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Exam Description"
        }
      },
      "required": [
        "report_text"
      ],
      "title": "EvalInput",
      "type": "object"
    },
    "EvalMetadata": {
      "additionalProperties": false,
      "description": "Metadata for a single eval case, used for filtering and reporting.",
      "properties": {
        "source_file": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source File"
        },
        "modality": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Modality"
        },
        "body_region": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Body Region"
        },
        "difficulty": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Difficulty"
        },
        "tags": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Tags",
          "type": "array"
        }
      },
      "title": "EvalMetadata",
      "type": "object"
    },
    "ExamInfo": {
      "additionalProperties": false,
      "description": "Metadata about the imaging exam this extraction came from.",
      "properties": {
        "study_description": {
          "description": "Study description, e.g., \"CT Abdomen and Pelvis WO contrast\"",
          "title": "Study Description",
          "type": "string"
        },
        "study_date": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "ISO date if known (YYYY-MM-DD)",
          "title": "Study Date"
        },
        "modality": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Modality code: \"CT\", \"XR\", \"MR\", \"US\", \"NM\", etc.",
          "title": "Modality"
        },
        "body_part": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Body part examined: \"abdomen\", \"chest\", \"brain\", \"shoulder\", etc.",
          "title": "Body Part"
        }
      },
      "required": [
        "study_description"
      ],
      "title": "ExamInfo",
      "type": "object"
    },
    "ExtractedFinding": {
      "additionalProperties": false,
      "description": "The core output model for each finding extracted from a radiology report.\n\nKey design points:\n- finding_name: concise, reusable clinical term (not a sentence)\n- presence: present/absent/indeterminate/possible. \"possible\" covers hedged language\n  like \"raising the possibility of\", \"suggestive of\", \"cannot exclude\"\n- Both present and absent findings extracted (\"no ascites\" → ascites/absent)\n- report_text must be a verbatim excerpt — quote, not paraphrase\n- Multiple instances of same finding type → separate entries",
      "properties": {
        "finding_name": {
          "description": "Concise clinical term: \"renal calculus\", \"hepatic steatosis\"",
          "title": "Finding Name",
          "type": "string"
        },
        "presence": {
          "description": "Presence status: present, absent, indeterminate, or possible (for hedged language)",
          "enum": [
            "present",
            "absent",
            "indeterminate",
            "possible"
          ],
          "title": "Presence",
          "type": "string"
        },
        "location": {
          "anyOf": [
            {
              "$ref": "#/$defs/FindingLocation"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Location of the finding, if applicable"
        },
        "attributes": {
          "description": "Descriptive attributes of the finding (size, acuity, change_from_prior, etc.)",
          "items": {
            "$ref": "#/$defs/FindingAttribute"
          },
          "title": "Attributes",
          "type": "array"
        },
        "report_text": {
          "description": "Verbatim quote from the report text that supports this finding",
          "title": "Report Text",
          "type": "string"
        }
      },
      "required": [
        "finding_name",
        "presence",
        "report_text"
      ],
      "title": "ExtractedFinding",
      "type": "object"
    },
    "FindingAttribute": {
      "additionalProperties": false,
      "description": "Any descriptive property of a finding beyond presence and location.\n\nFlexible key-value structure for attributes like size, acuity, change from prior,\nseverity, count, and morphology.",
      "properties": {
        "key": {
          "description": "Attribute key: \"size\", \"acuity\", \"change_from_prior\", \"severity\", \"count\", \"morphology\"",
          "title": "Key",
          "type": "string"
        },
        "value": {
          "description": "Attribute value: \"3 mm\", \"acute\", \"stable\", \"moderate\", \"2\", \"nonobstructing\"",
          "title": "Value",
          "type": "string"
        }
      },
      "required": [
        "key",
        "value"
      ],
      "title": "FindingAttribute",
      "type": "object"
    },
    "FindingLocation": {
      "additionalProperties": false,
      "description": "Where the finding is occurring.\n\nSeparate from other attributes because location is often implied by the exam type\nrather than stated explicitly in the report text.",
      "properties": {
        "body_region": {
          "description": "Body region",
          "enum": [
            "chest",
            "abdomen",
            "pelvis",
            "head",
            "neck",
            "spine",
            "upper extremity",
            "lower extremity",
            "breast"
          ],
          "title": "Body Region",
          "type": "string"
        },
        "specific_anatomy": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Specific anatomy: \"right lower lobe\", \"left kidney interpolar region\", \"T9 vertebral body\"",
          "title": "Specific Anatomy"
        },
        "laterality": {
          "anyOf": [
            {
              "enum": [
                "left",
                "right",
                "bilateral"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Laterality, or None if not applicable",
          "title": "Laterality"
        }
      },
      "required": [
        "body_region"
      ],
      "title": "FindingLocation",
      "type": "object"
    },
